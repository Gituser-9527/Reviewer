HOST=0.0.0.0
PORT=3001
API_BASE_URL=http://localhost:3001
DATABASE_URL=postgres://postgres:postgres@localhost:5432/job_compliance_agent
NODE_ENV=development
LOG_LEVEL=info

# LLM provider is optional. Tests and local MVP flows use mock/fallback behavior.
LLM_PROVIDER=mock
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# Privacy defaults: raw text should not be persisted in logs unless explicitly enabled.
ALLOW_UNREDACTED_RAW_TEXT=false
